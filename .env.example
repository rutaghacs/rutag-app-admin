# Server Configuration
PORT=3001

# Database Configuration
DB_HOST=localhost
DB_PORT=5432
DB_NAME=sensor_db
DB_USER=postgres
DB_PASSWORD=your_password_here

# Firebase Sync Configuration (optional but recommended)
# If configured, /api/users and /api/devices refresh PostgreSQL from Firestore.
FIREBASE_DATABASE_URL=https://your-project.firebaseio.com

# Option A: full service account JSON in one line
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account",...}

# Option B: base64-encoded full service account JSON
# FIREBASE_SERVICE_ACCOUNT_BASE64=eyJ0eXBlIjoic2VydmljZV9hY2NvdW50IiwuLi59

# Option C: individual fields
# FIREBASE_PROJECT_ID=your-project-id
# FIREBASE_PRIVATE_KEY_ID=your-private-key-id
# FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
# FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxx@your-project.iam.gserviceaccount.com
# FIREBASE_CLIENT_ID=1234567890
# FIREBASE_CLIENT_CERT_URL=https://www.googleapis.com/robot/v1/metadata/x509/firebase-adminsdk-xxxx%40your-project.iam.gserviceaccount.com

# How often the backend attempts Firestore sync on list/dashboard reads (milliseconds)
FIREBASE_SYNC_INTERVAL_MS=15000

# Optional: CORS Configuration
# ALLOWED_ORIGINS=http://localhost:3000,https://yourdomain.com
